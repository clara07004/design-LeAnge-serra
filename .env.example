# ─── gpt-image2-leange ───────────────────────────────────────
# Token gerado via: npx @openai/codex login
# Salvo automaticamente em ~/.codex/auth.json (não configurar manualmente)

# ─── nanobanana-leange ────────────────────────────────────────
# Obter em: https://aistudio.google.com (gratuito)
GEMINI_API_KEY=

# ─── publicar-social-leange (Instagram via Meta Graph API) ────
# Obter em: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Atenção: META_ACCESS_TOKEN expira em 60 dias — renovar via Graph API Explorer
# Obter em: https://imgbb.com (gratuito)
IMGBB_API_KEY=

# ─── image-gen-leange (contingência — FAL API) ────────────────
# Obter em: https://fal.ai (requer créditos ~$5)
FAL_KEY=
